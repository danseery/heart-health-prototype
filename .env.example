# Local-only prototype settings. Copy to backend/.env if you need overrides.
# Never commit real secrets, patient data, tokens, SQLite databases, or exports.

APP_ENV=local
APP_NAME=HeartHealth AI Prototype
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./local_data/hearthealth_dev.db
AI_PROVIDER=dummy
LOG_LEVEL=INFO
