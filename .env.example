# Local development settings. Copy to backend/.env if you need overrides.
# Never commit real secrets, patient data, tokens, SQLite databases, or exports.

APP_ENV=local
APP_NAME=HeartHealth AI
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./local_data/hearthealth_dev.db
AI_PROVIDER=dummy

# Set AI_PROVIDER=azure_openai to use Big Brain for assessment summaries.
# Supports Azure OpenAI endpoints (*.openai.azure.com) and Azure AI Foundry
# model endpoints (*.services.ai.azure.com).
# Keep real API keys in backend/.env only. Do not commit secrets.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
# Leave as 2024-10-21 for Azure OpenAI. The app uses 2024-05-01-preview
# automatically for *.services.ai.azure.com endpoints unless overridden.
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_SECONDS=20
AZURE_OPENAI_MAX_TOKENS=700

LOG_LEVEL=INFO
